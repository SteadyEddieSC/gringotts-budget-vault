/*
  Content-Security-Policy: default-src 'self'; base-uri 'none'; object-src 'none'; frame-ancestors 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self'; media-src 'none'; frame-src 'none'; worker-src 'none'; manifest-src 'self'; form-action 'self'; upgrade-insecure-requests
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), serial=(), bluetooth=(), browsing-topics=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin

/index.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/*.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/service-worker.js
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/src/*
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/styles/*
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/manifest.webmanifest
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
