        ".range-controls",
        ".report-range-grid",
        ".report-preview-toolbar",
        "#reportPreviewPage",
        ".report-page[data-report-page=\"summary\"]"
      ],
      "requiredHidden": [
        ".report-page[data-report-page=\"comparison\"]",
        ".report-page[data-report-page=\"insights\"]",
        ".report-page[data-report-page=\"plan\"]"
      ],
      "minimumReportPages": 8,
      "expectedRangeColumns": 4,
      "maximumHorizontalOverflow": 2,
      "minimumMainWidth": 1000
    },
    "reports-phone": {
