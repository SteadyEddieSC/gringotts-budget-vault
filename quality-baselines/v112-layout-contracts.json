{
  "version": "v116",
  "description": "Privacy-safe visual regression contracts. These compare structure, geometry, visibility, and responsive layout using only synthetic Playwright data; no screenshot pixels or household data are committed.",
  "snapshots": {
    "dashboard-desktop": {
      "viewport": { "width": 1440, "height": 1000 },
      "route": "Dashboard",
      "requiredVisible": [
        ".topbar",
        ".primary-nav",
        "#main",
        ".section.active"
      ],
      "requiredHidden": ["#menuToggle"],
      "minimumPrimaryTabs": 6,
      "minimumCards": 3,
      "maximumHorizontalOverflow": 2,
      "minimumMainWidth": 1000,
      "maximumTopbarY": 32
    },
    "reports-desktop": {
      "viewport": { "width": 1440, "height": 1000 },
